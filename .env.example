# Copy this file to .env and fill in real values locally.
# NEVER commit the real .env file.

# Zendesk-style Help Center "articles" API, first page URL.
SOURCE_API_URL=https://support.optisigns.com/api/v2/help_center/en-us/articles.json

# Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Display name for the File Search store, only used the first time it's
# created. After that, its real resource name (fileSearchStores/xxx) is
# read from state.json on every subsequent run.
FILE_SEARCH_STORE_DISPLAY_NAME=OptiBot Knowledge Base

# Chat model used to answer questions, grounded via the file_search tool.
CHAT_MODEL=gemini-2.5-flash

# Cap article count for local testing (0 = no cap, scrape everything)
MAX_ARTICLES=30
